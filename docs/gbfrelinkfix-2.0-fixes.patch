From c3ebee332d33d8ea2aa6895cc803565831d900e5 Mon Sep 17 00:00:00 2001
From: alexfrljuckic <alexfrljuckic@gmail.com>
Date: Thu, 9 Jul 2026 17:01:40 -0400
Subject: [PATCH 3/3] feat: configurable Span HUD for 2.0 (ultrawide HUD to
 screen edges)

Ports master's SpanAllHUD to the 2.0 rewrite. Master's UI-Constraints
pattern still matches uniquely; at +0x1C the element constraint w/h are
freshly loaded (vmovss xmm2,[rax+0x1BC]/xmm0,[rax+0x1C0]). Struct layout
recovered via an in-mod diagnostic hook (anti-debug blocks x64dbg):
ref/constraint dims at 0x1B4/0x1B8 and 0x1BC/0x1C0. Spans any element
authored at 3840x2160 by overriding the register (no struct mutation).
Excludes world-positioned elements (NPC quest bubbles) via the
rax+0x1CC position-offset sentinel so markers stay pinned. New [Span HUD]
config (Enabled + AspectRatio).

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 GBFRelinkFix.ini | 11 +++++------
 src/config.h     |  3 +++
 src/dllmain.cpp  | 27 ++++++++++++++++++++++++++-
 3 files changed, 34 insertions(+), 7 deletions(-)

diff --git a/GBFRelinkFix.ini b/GBFRelinkFix.ini
index b87c902..d5a7088 100644
--- a/GBFRelinkFix.ini
+++ b/GBFRelinkFix.ini
@@ -24,14 +24,13 @@ Distance = 1.0
 Enabled = true
 
 [Span HUD]
-; Spans gameplay HUD.
-; If set to 0, the HUD aspect ratio will be the same as your resolution's aspect ratio.
-; Set to 1.7778 for a 16:9 HUD, 2.38888 for a 21:9 HUD or 3.5537 for a 32:9 HUD for example.
-; You can also force all HUD elements to be spanned (like menus etc) and span all background images (i.e main menu background etc). Note that this may cause visual issues.
+; Spans HUD elements out to the full screen width on ultrawide (party list, prompts, etc.)
+; instead of keeping them in a centered 16:9 band. May cause visual oddities on some
+; menus/backgrounds — set Enabled = false if you prefer the centered HUD.
+; AspectRatio: 0 = use your actual screen aspect. Or force one, e.g. 2.38888 for 21:9,
+; 1.7778 for 16:9, 3.5537 for 32:9.
 Enabled = true
 AspectRatio = 0
-SpanAllHUD = false
-SpanAllBackgrounds = false
 
 [Fix FOV]
 ; Fixes cropped FOV at <16:9.
diff --git a/src/config.h b/src/config.h
index bac583a..342c28f 100644
--- a/src/config.h
+++ b/src/config.h
@@ -99,6 +99,9 @@ namespace Config
     inline Item<bool> FixHUD           { "Fix HUD", "Enabled", false };
     inline Item<bool> FixFOV           { "Fix FOV", "Enabled", false };
 
+    inline Item<bool> SpanHUD          { "Span HUD", "Enabled", false };
+    inline Item<float> HUDAspectRatio  { "Span HUD", "AspectRatio", 0.0f, 0.0f, 32.0f };
+
     inline Item<int> ShadowResolution  { "Shadow Quality", "Resolution", 2048, 64, 16384 };
     inline Item<float> LODDistMult     { "Level of Detail", "Multiplier", 1.0f, 0.01f, 5.0f };
     inline Item<bool> DisableTAA       { "Disable TAA", "Enabled", false };
diff --git a/src/dllmain.cpp b/src/dllmain.cpp
index b6b874e..434a006 100644
--- a/src/dllmain.cpp
+++ b/src/dllmain.cpp
@@ -95,11 +95,36 @@ void HUD()
 {
     if (Config::FixHUD) {
         // Fix HUD cropping at >16:9
-        MAKE_MIDHOOK(HUDScale_sh, "HUD: Scale", "C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? 5C ?? C5 ?? 57 ?? C5 ?? 59 ??", 0, [](SafetyHookContext& ctx) {          
+        MAKE_MIDHOOK(HUDScale_sh, "HUD: Scale", "C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? 5C ?? C5 ?? 57 ?? C5 ?? 59 ??", 0, [](SafetyHookContext& ctx) {
             if (Screen::AspectRatio > Screen::NativeAspect)
                 ctx.xmm0.f32[0] = ctx.xmm1.f32[0] * Screen::NativeAspect;
         });
 
+        // Span HUD elements to the full screen width (ultrawide) instead of the 16:9 safe area.
+        // Ported from master's SpanAllHUD: master's "UI Constraints" pattern still matches uniquely
+        // on 2.0. At +0x1C the element's constraint w/h are freshly loaded (vmovss xmm2,[rax+0x1BC] /
+        // xmm0,[rax+0x1C0]); for any element authored at 3840x2160, override the register so its
+        // layout spans the real aspect. Register-only writes (no struct mutation) = safe.
+        if (Config::SpanHUD) {
+            MAKE_MIDHOOK(SpanHUD_sh, "HUD: Span", "48 ?? ?? ?? ?? ?? 00 48 ?? ?? 74 ?? C5 ?? ?? ?? ?? ?? ?? 00 C5 ?? ?? ?? ?? ?? ?? 00 C5 ?? ?? ?? ?? ?? ?? 00 EB ??", 0x1C, [](SafetyHookContext& ctx) {
+                if (!ctx.rax) return;
+                const float hudAspect = (Config::HUDAspectRatio > 0.0f) ? Config::HUDAspectRatio.Get() : Screen::AspectRatio;
+                const float cW = *reinterpret_cast<float*>(ctx.rax + 0x1BC);
+                const float cH = *reinterpret_cast<float*>(ctx.rax + 0x1C0);
+                // Only span static, screen-anchored HUD elements. World-positioned elements
+                // (NPC quest bubbles / on-screen markers) use rax+0x1CC as a live position
+                // offset; static HUD leaves it at the 0xFFFFFFFF sentinel. Skip the former so
+                // markers stay pinned to their world targets.
+                const std::uint32_t posOffset = *reinterpret_cast<std::uint32_t*>(ctx.rax + 0x1CC);
+                if (cW == 3840.0f && cH == 2160.0f && posOffset == 0xFFFFFFFFu) {
+                    if (Screen::AspectRatio > Screen::NativeAspect)
+                        ctx.xmm2.f32[0] = 2160.0f * hudAspect;
+                    else if (Screen::AspectRatio < Screen::NativeAspect)
+                        ctx.xmm0.f32[0] = 3840.0f / hudAspect;
+                }
+            });
+        }
+
         // Fix markers
         // Release 2.0 (2026-07-08): vdivss folded out of the sequence and the HUD reference
         // width/height struct slots shifted +0x8 (0x1B4/0x1B8 -> 0x1BC/0x1C0). Base reg still r14
-- 
