+// One-shot diagnostic: dump a UI element's layout struct the first time each target id shows
+// up, so a single game run confirms master's element ids still live at +0x1C4 on 2.0 and shows
+// the pre-write +0x1CC/+0x1D0 offset state. (In-mod logging stands in for a debugger: the game
+// crashes x64dbg on attach.)
+static void LogUIElementOnce(int slot, const char* name, std::uintptr_t elem)
+{
+    static bool logged[3]{};
+    if (slot < 0 || slot > 2 || logged[slot]) return;
+    logged[slot] = true;
+    LOG_INFO("HUD: Span: {} seen: id={:#010x} W={} H={} off0x1CC={:#010x}({}) off0x1D0={:#010x}({})",
+        name,
+        *reinterpret_cast<std::uint32_t*>(elem + 0x1C4),
+        *reinterpret_cast<float*>(elem + 0x1BC),
+        *reinterpret_cast<float*>(elem + 0x1C0),
+        *reinterpret_cast<std::uint32_t*>(elem + 0x1CC),
+        *reinterpret_cast<float*>(elem + 0x1CC),
+        *reinterpret_cast<std::uint32_t*>(elem + 0x1D0),
+        *reinterpret_cast<float*>(elem + 0x1D0));
+}
+
+// One-shot-per-id diagnostic for the UI Size Setter: records which elements pass through
+// at 3840x2160 so a single game run maps the background/effect candidates (menu bg, combat
+// overlays) without a debugger. Capped so the log stays readable.
+static void LogSizeSetterOnce(std::uintptr_t elem)
+{
+    static std::uint32_t seen[48];
+    static int seenCount = 0;
+    const std::uint32_t id = *reinterpret_cast<std::uint32_t*>(elem + 0x1C4);
+    for (int i = 0; i < seenCount; i++)
+        if (seen[i] == id) return;
+    if (seenCount >= 48) return;
+    seen[seenCount++] = id;
+    LOG_INFO("Span Backgrounds: 3840x2160 element: id={:#010x} off0x1CC={:#010x} off0x1D0={:#010x}",
+        id,
+        *reinterpret_cast<std::uint32_t*>(elem + 0x1CC),
+        *reinterpret_cast<std::uint32_t*>(elem + 0x1D0));
+}
+
 void HUD()
 {
     if (Config::FixHUD) {
@@ -105,10 +143,37 @@ void HUD()
         // on 2.0. At +0x1C the element's constraint w/h are freshly loaded (vmovss xmm2,[rax+0x1BC] /
