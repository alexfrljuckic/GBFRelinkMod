 {
     if (Config::FixHUD) {
         // Fix HUD cropping at >16:9
-        MAKE_MIDHOOK(HUDScale_sh, "HUD: Scale", "C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? 5C ?? C5 ?? 57 ?? C5 ?? 59 ??", 0, [](SafetyHookContext& ctx) {          
+        MAKE_MIDHOOK(HUDScale_sh, "HUD: Scale", "C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? 5C ?? C5 ?? 57 ?? C5 ?? 59 ??", 0, [](SafetyHookContext& ctx) {
             if (Screen::AspectRatio > Screen::NativeAspect)
                 ctx.xmm0.f32[0] = ctx.xmm1.f32[0] * Screen::NativeAspect;
