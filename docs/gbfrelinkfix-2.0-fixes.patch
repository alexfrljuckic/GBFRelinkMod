From 04ade02ed3696dae2af4b4a03931c7cbaa6f109d Mon Sep 17 00:00:00 2001
From: alexfrljuckic <alexfrljuckic@gmail.com>
Date: Thu, 9 Jul 2026 15:40:42 -0400
Subject: [PATCH 1/2] fix: repair Press Any Key signature for release 2.0 (49
 8B -> 49 3B)

Trailing mov became cmp in the 2026-07-08 release build; new sig verified
unique against the shipped exe. Builds clean with xmake + MSVC 2022.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 external/inipp  | 1 +
 external/spdlog | 1 +
 src/dllmain.cpp | 3 ++-
 3 files changed, 4 insertions(+), 1 deletion(-)
 create mode 160000 external/inipp
 create mode 160000 external/spdlog

diff --git a/external/inipp b/external/inipp
new file mode 160000
index 0000000..3c16688
--- /dev/null
+++ b/external/inipp
@@ -0,0 +1 @@
+Subproject commit 3c1668812026f1a94471b85ac5ab11ab87c43607
diff --git a/external/spdlog b/external/spdlog
new file mode 160000
index 0000000..b18a234
--- /dev/null
+++ b/external/spdlog
@@ -0,0 +1 @@
+Subproject commit b18a234ed6af38638678a3338c0d7ed90210ae6c
diff --git a/src/dllmain.cpp b/src/dllmain.cpp
index 6e3986d..6d36f9d 100644
--- a/src/dllmain.cpp
+++ b/src/dllmain.cpp
@@ -15,7 +15,8 @@ void SkipIntro()
         }
 
         // Skip title logo and press any key
-        if (auto* PressAnyKey = Memory::FindPattern("Press Any Key", "0F 84 ?? ?? ?? ?? 4D 85 ?? 0F 84 ?? ?? ?? ?? 49 8B ?? ?? ?? ?? ?? 49 8B ?? ?? ?? ?? ??"))
+        // Release 2.0 (2026-07-08): trailing `mov` (49 8B) became `cmp` (49 3B); patched jz prefix unchanged.
+        if (auto* PressAnyKey = Memory::FindPattern("Press Any Key", "0F 84 ?? ?? ?? ?? 4D 85 ?? 0F 84 ?? ?? ?? ?? 49 8B ?? ?? ?? ?? ?? 49 3B ?? ?? ?? ?? ??"))
             Memory::PatchBytes(PressAnyKey, "\x90\x90\x90\x90\x90\x90");
     }
 }
-- 
2.55.0.windows.2


From 3c3efc65e16609c360aa7bcb70a65fcbd610637b Mon Sep 17 00:00:00 2001
From: alexfrljuckic <alexfrljuckic@gmail.com>
Date: Thu, 9 Jul 2026 16:32:15 -0400
Subject: [PATCH 2/2] fix: repair HUD: Markers hook for release 2.0

vdivss folded out of the sequence (new unique pattern); HUD reference
width/height struct slots shifted +0x8 (0x1B4/0x1B8 -> 0x1BC/0x1C0),
base reg still r14 (confirmed via vmovsd xmm1,[r14+0x1BC] preceding the
site). Found by an in-mod diagnostic hook, not a debugger (game has
anti-debug). All 15 patterns now resolve on 2.0.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 src/dllmain.cpp | 15 +++++++++------
 1 file changed, 9 insertions(+), 6 deletions(-)

diff --git a/src/dllmain.cpp b/src/dllmain.cpp
index 6d36f9d..b6b874e 100644
--- a/src/dllmain.cpp
+++ b/src/dllmain.cpp
@@ -101,16 +101,19 @@ void HUD()
         });
 
         // Fix markers
-        MAKE_MIDHOOK(Markers_sh, "HUD: Markers", "C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? 5E ?? C5 ?? D0 ?? 0F B6 ?? ?? ?? ?? ??", 0, [](SafetyHookContext& ctx) {          
+        // Release 2.0 (2026-07-08): vdivss folded out of the sequence and the HUD reference
+        // width/height struct slots shifted +0x8 (0x1B4/0x1B8 -> 0x1BC/0x1C0). Base reg still r14
+        // (confirmed via `vmovsd xmm1,[r14+0x1BC]` immediately preceding the hook site).
+        MAKE_MIDHOOK(Markers_sh, "HUD: Markers", "C5 ?? 59 ?? ?? ?? ?? ?? C5 ?? D0 ?? 0F B6 ?? ?? ?? ?? ??", 0, [](SafetyHookContext& ctx) {
             if (Screen::AspectRatio > Screen::NativeAspect) {
                 float width = 2160.0f * Screen::AspectRatio;
-                if (ctx.xmm2.f32[0] != width)
-                    *reinterpret_cast<float*>(ctx.r14 + 0x1B4) = width;
+                if (*reinterpret_cast<float*>(ctx.r14 + 0x1BC) != width)
+                    *reinterpret_cast<float*>(ctx.r14 + 0x1BC) = width;
             }
             else {
                 float height = 3840.0f / Screen::AspectRatio;
-                if (ctx.xmm2.f32[1] != height)
-                    *reinterpret_cast<float*>(ctx.r14 + 0x1B8) = height;
+                if (*reinterpret_cast<float*>(ctx.r14 + 0x1C0) != height)
+                    *reinterpret_cast<float*>(ctx.r14 + 0x1C0) = height;
             }
         });
     }
@@ -171,7 +174,7 @@ DWORD __stdcall Main(void*)
     HUD();
     Graphics();
     Framerate();
-        
+
     return 0;
 }
 
-- 
2.55.0.windows.2

