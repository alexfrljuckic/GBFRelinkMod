+        // containers: when the HUD spans, the game still places them at the 16:9 band edges,
+        // so master pushed them out to the real screen edges via the +0x1CC/+0x1D0 position
+        // offsets. Element ids from master, read at the 2.0 id slot +0x1C4.
+        if (Config::SpanHUD || Config::FixLockOn || Config::FixDodge) {
             MAKE_MIDHOOK(SpanHUD_sh, "HUD: Span", "48 ?? ?? ?? ?? ?? 00 48 ?? ?? 74 ?? C5 ?? ?? ?? ?? ?? ?? 00 C5 ?? ?? ?? ?? ?? ?? 00 C5 ?? ?? ?? ?? ?? ?? 00 EB ??", 0x1C, [](SafetyHookContext& ctx) {
                 if (!ctx.rax) return;
                 const float hudAspect = (Config::HUDAspectRatio > 0.0f) ? Config::HUDAspectRatio.Get() : Screen::AspectRatio;
+                const std::uint32_t id = *reinterpret_cast<std::uint32_t*>(ctx.rax + 0x1C4);
+
+                if (id == 1719602056u) // Gameplay HUD (diagnostic only; spanned by the generic path below)
+                    LogUIElementOnce(0, "GameplayHUD", ctx.rax);
+
+                if (Config::FixLockOn && id == 605904162u) { // Guard & Lock-On
+                    LogUIElementOnce(1, "GuardLockOn", ctx.rax);
+                    if (Screen::AspectRatio > Screen::NativeAspect)
+                        *reinterpret_cast<float*>(ctx.rax + 0x1CC) = -((2160.0f * hudAspect - 3840.0f) / 2.0f);
+                    else if (Screen::AspectRatio < Screen::NativeAspect)
+                        *reinterpret_cast<float*>(ctx.rax + 0x1D0) = -((3840.0f / hudAspect - 2160.0f) / 2.0f);
+                }
+
+                if (Config::FixDodge && id == 3550204025u) { // Dodge
+                    LogUIElementOnce(2, "Dodge", ctx.rax);
+                    if (Screen::AspectRatio > Screen::NativeAspect)
+                        *reinterpret_cast<float*>(ctx.rax + 0x1CC) = (2160.0f * hudAspect - 3840.0f) / 2.0f;
+                    else if (Screen::AspectRatio < Screen::NativeAspect)
+                        *reinterpret_cast<float*>(ctx.rax + 0x1D0) = -((3840.0f / hudAspect - 2160.0f) / 2.0f);
+                }
+
+                if (!Config::SpanHUD) return;
                 const float cW = *reinterpret_cast<float*>(ctx.rax + 0x1BC);
                 const float cH = *reinterpret_cast<float*>(ctx.rax + 0x1C0);
                 // Only span static, screen-anchored HUD elements. World-positioned elements
@@ -142,6 +207,30 @@ void HUD()
             }
         });
     }
+
+    // Span full-screen backgrounds (menu/pause/load screens, fades, overlays) at the
+    // source: the "UI Size Setter" is where every element's constraint W/H is written
+    // ([rax+0x1BC]=W / [rax+0x1C0]=H, from an input rect). The same code is stamped out
+    // at three sites in the exe (byte-identical modulo rip displacements), hence
+    // MAKE_MIDHOOK_ALL. Overriding the registers here resizes the element for every
+    // downstream consumer — unlike the earlier rect-builder attempt (exe+0x3340ad5),
+    // whose output turned out not to be the visible background. At the hook (+0x1A =
+    // the vmovss [rax+0x1BC], xmm0 store): xmm0 = W, xmm1 = H; the reference W/H
+    // stores earlier in the function keep their original 3840/2160.
+    if (Config::SpanBackgrounds) {
+        MAKE_MIDHOOK_ALL(SizeSetter_sh, "UI Size Setter", "C5 ?? 54 ?? ?? ?? ?? ?? C5 ?? 2E ?? ?? ?? ?? ?? 77 ?? C5 ?? 11 ?? B8 01 00 00 C5 ?? 11 ?? BC 01 00 00 C5 ?? 11 ?? C0 01 00 00 C3", 0x1A, [](SafetyHookContext& ctx) {
