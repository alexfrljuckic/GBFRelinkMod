+            if (*reinterpret_cast<std::uint32_t*>(ctx.rax + 0x1CC) != 0xFFFFFFFFu) return;
+            const float bgAspect = (Config::BGAspectRatio > 0.0f) ? Config::BGAspectRatio.Get() : Screen::AspectRatio;
