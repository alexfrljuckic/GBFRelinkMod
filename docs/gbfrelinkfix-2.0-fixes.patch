+    // All-matches variant: same scan, accumulates instead of returning on first hit.
+    template <size_t ChunkSize>
+    std::vector<std::uint8_t*> ExecuteSIMDScanAll(const void* module, const ParsedPattern& p, bool scanAll)
+    {
+        using T = SIMDTraits<ChunkSize>;
+        const auto needle = T::Set1(static_cast<char>(p.bytes[p.anchorIdx]));
+        std::vector<std::uint8_t*> results;
+
+        for (const auto& section : GetModuleSections(module, scanAll)) {
+            if (section.size() < p.size) continue;
+
+            const uint8_t* data = section.data();
+            const size_t end = section.size() - p.size;
+
+            for (size_t offset = 0; offset < end; ++offset) {
+                if (offset + ChunkSize <= end) {
+                    uint32_t mask = T::Mask(T::Load(data + offset + p.anchorIdx), needle);
+                    while (mask) {
+                        size_t pos = offset + T::GetNextBit(mask);
+                        if (VerifyMatch(data + pos, p.verifyPairs, p.vpCount))
+                            results.push_back(const_cast<uint8_t*>(data + pos));
+                        mask &= (mask - 1);
+                    }
+                    offset += (ChunkSize - 1);
+                }
+                else if (data[offset + p.anchorIdx] == p.bytes[p.anchorIdx]) {
+                    if (VerifyMatch(data + offset, p.verifyPairs, p.vpCount))
+                        results.push_back(const_cast<uint8_t*>(data + offset));
+                }
+            }
+        }
+        return results;
+    }
+
